# Domaine du VPS (ex: mondomaine.com ou IP brute)
DOMAIN_NAME=your_domain_or_ip

# Sous-domaine pour accéder à n8n (résultat : https://SUBDOMAIN.DOMAIN_NAME)
SUBDOMAIN=n8n

# Email pour le certificat SSL Let's Encrypt
SSL_EMAIL=your_email@example.com

# Timezone (ex: Europe/Paris, America/New_York)
GENERIC_TIMEZONE=Europe/Paris

# Paramètres d'exécution n8n
N8N_EXECUTIONS_PROCESS=main
EXECUTIONS_DATA_PRUNE=true
