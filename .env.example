# Telegram API credentials
# Obtenir sur https://my.telegram.org/apps
TELEGRAM_API_ID=your_api_id
TELEGRAM_API_HASH=your_api_hash

# Nom du fichier de session Telethon (sans extension)
SESSION_NAME=session

# Port d'écoute du serveur Flask
PORT=5000

# Dossier temporaire pour les médias téléchargés
TMP_DIR=/tmp/tg_media